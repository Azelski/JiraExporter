{
  "name": "jira-exporter",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "Chrome extension that exports Jira tickets to ZIP for LLM context.",
  "author": "Jacek Azelski",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Azelski/JiraExporter.git"
  },
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "clean": "rm -rf dist",
    "package": "pnpm build && node -e \"const v=require('./dist/manifest.json').version;require('child_process').execSync('cd dist && zip -r ../jira-exporter-'+v+'.zip .',{stdio:'inherit',shell:true})\""
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "node-html-markdown": "^2.0.0"
  },
  "devDependencies": {
    "vite": "^6.3.2"
  }
}
